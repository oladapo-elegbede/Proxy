# .env.example
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local to git.

# -------------------------------------------------------
# Anthropic — used for intake pipeline and conversation architect
# Get your key at: https://console.anthropic.com
# -------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------
# OpenAI — used for embeddings (RAG) and simulator pipeline
# Get your key at: https://platform.openai.com/api-keys
# -------------------------------------------------------
OPENAI_API_KEY=

# -------------------------------------------------------
# Pinecone — used for policy corpus vector search
# Get your key at: https://app.pinecone.io
# -------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=proxy-policy-corpus

# -------------------------------------------------------
# Application
# -------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------
# Feature flags — set to "true" to enable
# -------------------------------------------------------
NEXT_PUBLIC_ENABLE_SIMULATOR=false
NEXT_PUBLIC_ENABLE_RIGHTS_ENGINE=false
NEXT_PUBLIC_DEMO_MODE=false